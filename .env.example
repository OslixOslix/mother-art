APP_NAME="Елена Буркальцева"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production (Railway + custom domain): APP_URL=https://elenaburkaltseva.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_EMAIL=elena-burkaltseva@yandex.ru
ADMIN_NAME="Елена Буркальцева"
ADMIN_PASSWORD=
ADMIN_ORDER_EMAIL="hello@example.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENROUTER_API_KEY=
OPENROUTER_MODEL=sourceful/riverflow-v2.5-pro
OPENROUTER_NAMING_MODEL=google/gemini-3.1-flash-image
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=600
OPENROUTER_HTTP_REFERER="${APP_URL}"
# Production: явно https://elenaburkaltseva.com, если Railway не подставляет ${APP_URL}
OPENROUTER_APP_TITLE="${APP_NAME}"
OPENROUTER_IMPORT_IMAGE_SIZE=2K
OPENROUTER_MAX_BASE64_BYTES=3500000
